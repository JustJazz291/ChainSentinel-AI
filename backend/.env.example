# ChainSentinel AI Backend – Environment Variables
# Copy this file to .env and fill in your keys

PORT=3001

# Etherscan API key (free tier works fine) – used to fetch contract ABI/source
ETHERSCAN_API_KEY=YourEtherscanKeyHere

# Optional: BSCscan, Polygonscan, Arbiscan, etc.
BSCSCAN_API_KEY=YourBscKeyHere
POLYGONSCAN_API_KEY=YourPolyKeyHere
ARBISCAN_API_KEY=YourArbKeyHere
OPTIMISM_API_KEY=YourOptKeyHere
SNOWTRACE_API_KEY=YourAvaxKeyHere

# OpenAI key for AI explanations (optional – falls back to rule-based)
OPENAI_API_KEY=
